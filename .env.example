NUXT_PUBLIC_REQUIRE_AUTH=true
NUXT_OWNER_GITHUB_HANDLE=
# Password for nuxt-auth-utils (minimum 32 characters)
NUXT_SESSION_PASSWORD=
# GitHub OAuth client ID
NUXT_OAUTH_GITHUB_CLIENT_ID=
# GitHub OAuth client secret
NUXT_OAUTH_GITHUB_CLIENT_SECRET=
# Anthropic API key (direct, used by @ai-sdk/anthropic)
ANTHROPIC_API_KEY=
# Voyage API key for RAG
VOYAGE_API_KEY=
# Test-only (dev/non-production), off by default. Never wire into the UI.
# Single switch for rapid offline dev: replaces all external systems (LLM,
# Voyage, GitHub) with deterministic offline fakes AND enables test-login
# (GET /auth/test-login, defaults the handle to "tester") and the fixture-repo
# seed route (GET /test/seed-repo). No API keys or PAT needed.
NUXT_FAKE_EXTERNALS=
# Enable test-login on its own (mint a session without GitHub OAuth) while still
# hitting the REAL externals — pair with NUXT_TEST_GITHUB_TOKEN for real snapshots.
NUXT_ALLOW_TEST_LOGIN=
# Optional PAT (repo scope) for test-login's session, to exercise real snapshots.
NUXT_TEST_GITHUB_TOKEN=
